<mxfile host="app.diagrams.net">
  <diagram name="訓練流程" id="v34-training-flow">
    <mxGraphModel dx="1440" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;" value="Training &amp; Deployment Flow (v3.4)" vertex="1">
          <mxGeometry x="160" y="10" width="580" height="40" as="geometry" />
        </mxCell>

        <mxCell id="actor" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=20;" value="Researcher" vertex="1">
          <mxGeometry x="100" y="80" width="60" height="100" as="geometry" />
        </mxCell>

        <mxCell id="s-distill" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Input prompt to&#10;distil data from teacher model" vertex="1">
          <mxGeometry x="220" y="100" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-jsonl" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Convert distilled data to JSONL&#10;(Instruction · question · think · answer)" vertex="1">
          <mxGeometry x="220" y="210" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-prep" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Preprocess training data&#10;(tokenize · build_prompt · label mask)" vertex="1">
          <mxGeometry x="220" y="320" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-load" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Load student model&#10;(Qwen3-Coder-30B-A3B-Instruct,&#10;NF4 + bf16 compute, QLoRA-prepared)" vertex="1">
          <mxGeometry x="220" y="430" width="280" height="100" as="geometry" />
        </mxCell>

        <mxCell id="s-lora" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Inject LoRA adapter&#10;(r=64, α=64, dropout=0.1,&#10;q/k/v/o + gate/up/down_proj)" vertex="1">
          <mxGeometry x="220" y="560" width="280" height="100" as="geometry" />
        </mxCell>

        <mxCell id="s-train" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Input data and start training&#10;(cosine LR · grad accum 64 · adamw_8bit)" vertex="1">
          <mxGeometry x="220" y="690" width="280" height="90" as="geometry" />
        </mxCell>

        <mxCell id="s-merge" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=20;" value="Merge back into&#10;the base model?" vertex="1">
          <mxGeometry x="220" y="810" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="lbl-merge-yes" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=2;" value="Yes" vertex="1">
          <mxGeometry x="100" y="855" width="80" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lbl-merge-no" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=2;" value="No (keep as adapter)" vertex="1">
          <mxGeometry x="510" y="855" width="220" height="30" as="geometry" />
        </mxCell>

        <mxCell id="s-mergeop" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Merge adapter into base&#10;(merge_and_unload)" vertex="1">
          <mxGeometry x="50" y="900" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-out" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Save LoRA artifacts&#10;outputs-lora-qwen3-coder-30b/" vertex="1">
          <mxGeometry x="220" y="980" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-deploy" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;fillColor=#d4edda;strokeColor=#28a745;" value="Deploy: docker rebuild-server.sh&#10;mount adapter into inference container" vertex="1">
          <mxGeometry x="540" y="980" width="320" height="90" as="geometry" />
        </mxCell>

        <mxCell id="s-guard" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;fillColor=#f8d7da;strokeColor=#dc3545;" value="Boot guard&#10;_verify_non_eager_attention()&#10;refuse-to-start if eager / unknown" vertex="1">
          <mxGeometry x="540" y="1090" width="320" height="100" as="geometry" />
        </mxCell>

        <mxCell id="e-actor" parent="1" edge="1" source="actor" target="s-distill" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e1" parent="1" edge="1" source="s-distill" target="s-jsonl" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" parent="1" edge="1" source="s-jsonl" target="s-prep" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" parent="1" edge="1" source="s-prep" target="s-load" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" parent="1" edge="1" source="s-load" target="s-lora" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" parent="1" edge="1" source="s-lora" target="s-train" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" parent="1" edge="1" source="s-train" target="s-merge" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7-yes" parent="1" edge="1" source="s-merge" target="s-mergeop" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7-no" parent="1" edge="1" source="s-merge" target="s-out" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7-merge-out" parent="1" edge="1" source="s-mergeop" target="s-out" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-out-deploy" parent="1" edge="1" source="s-out" target="s-deploy" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-deploy-guard" parent="1" edge="1" source="s-deploy" target="s-guard" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
