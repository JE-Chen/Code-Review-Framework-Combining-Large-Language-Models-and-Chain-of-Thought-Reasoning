        <mxCell id="e-shard-no" parent="1" edge="1" source="s-shard" target="s-agg" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;dashed=1;exitX=1;exitY=0.5;entryX=1;entryY=0;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="450" />
              <mxPoint x="700" y="1780" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-shard-yes" parent="1" edge="1" source="s-shard" target="s-load" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
