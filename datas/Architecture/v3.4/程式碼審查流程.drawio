        <mxCell id="s-agg" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;fillColor=#ffe6cc;strokeColor=#d79b00;" value="Aggregate partials + diff-hunk filter&#10;synthesise PR-wide Overall Summary&#10;cap at 60 000 chars" vertex="1">
          <mxGeometry x="280" y="1730" width="340" height="100" as="geometry" />
