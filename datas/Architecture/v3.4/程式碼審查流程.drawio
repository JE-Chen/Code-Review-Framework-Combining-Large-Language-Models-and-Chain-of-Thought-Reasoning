        <mxCell id="e-enum" parent="1" edge="1" source="s-enum" target="s-shard" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
