<mxfile host="app.diagrams.net">
  <diagram name="程式碼審查流程" id="v34-review-flow">
    <mxGraphModel dx="1440" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;" value="Code Review Flow (v3.4)" vertex="1">
          <mxGeometry x="200" y="10" width="500" height="40" as="geometry" />
        </mxCell>

        <mxCell id="s-push" parent="1" style="ellipse;whiteSpace=wrap;html=1;fontSize=20;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="PR push / synchronize" vertex="1">
          <mxGeometry x="340" y="70" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s-restore" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;fillColor=#fff2cc;strokeColor=#d6b656;" value="Restore per-PR pr-state cache&#10;(manifest + prior partials)" vertex="1">
          <mxGeometry x="320" y="170" width="260" height="70" as="geometry" />
        </mxCell>

        <mxCell id="s-enum" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Enumerate PR files&#10;(filter out unchanged blob SHAs)" vertex="1">
          <mxGeometry x="320" y="280" width="260" height="70" as="geometry" />
        </mxCell>

        <mxCell id="s-shard" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=20;" value="Any file&#10;to review?" vertex="1">
          <mxGeometry x="340" y="390" width="220" height="120" as="geometry" />
        </mxCell>

        <mxCell id="lbl-no" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=2;" value="No (all cached)" vertex="1">
          <mxGeometry x="580" y="430" width="150" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lbl-yes" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=2;" value="Yes" vertex="1">
          <mxGeometry x="400" y="510" width="80" height="30" as="geometry" />
        </mxCell>

        <mxCell id="s-load" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Load source code (per-file shard)" vertex="1">
          <mxGeometry x="320" y="570" width="260" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s-rag" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Query RAG &amp; knowledge layers&#10;(rules · corpora · KG)" vertex="1">
          <mxGeometry x="320" y="660" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-relevant" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=20;" value="Any relevant&#10;rules / lessons / symbols?" vertex="1">
          <mxGeometry x="320" y="770" width="260" height="140" as="geometry" />
        </mxCell>

        <mxCell id="lbl-yes2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=2;" value="Yes" vertex="1">
          <mxGeometry x="600" y="820" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lbl-no2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=2;" value="No" vertex="1">
          <mxGeometry x="430" y="910" width="60" height="30" as="geometry" />
        </mxCell>

        <mxCell id="s-inject" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Inject retrieved context&#10;into prompt template" vertex="1">
          <mxGeometry x="650" y="800" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-build" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Build review prompt&#10;(global_rule wrapper + step body)" vertex="1">
          <mxGeometry x="320" y="950" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-step" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;fillColor=#e1d5e7;strokeColor=#9673a6;" value="Run CoT step&#10;(model.generate, cancel-aware,&#10;6 000-char step output cap)" vertex="1">
          <mxGeometry x="320" y="1060" width="260" height="90" as="geometry" />
        </mxCell>

        <mxCell id="s-incr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=18;fillColor=#fff2cc;strokeColor=#d6b656;" value="Incremental save (atomic)&#10;.prthinker/runs/files/&lt;file&gt;.json" vertex="1">
          <mxGeometry x="50" y="1075" width="240" height="70" as="geometry" />
        </mxCell>

        <mxCell id="s-done" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=20;" value="All 5 steps done&#10;for this file?" vertex="1">
          <mxGeometry x="320" y="1180" width="260" height="140" as="geometry" />
        </mxCell>

        <mxCell id="lbl-noloop" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=2;" value="No" vertex="1">
          <mxGeometry x="600" y="1230" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lbl-yesdone" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=2;" value="Yes" vertex="1">
          <mxGeometry x="430" y="1320" width="60" height="30" as="geometry" />
        </mxCell>

        <mxCell id="s-total" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Inject prior step outputs&#10;into total_summary prompt" vertex="1">
          <mxGeometry x="320" y="1360" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-check" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;fillColor=#fff2cc;strokeColor=#d6b656;" value="Shard checkpoint&#10;(save partial + blob_sha to pr-state)" vertex="1">
          <mxGeometry x="320" y="1460" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-more" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=20;" value="More files&#10;in matrix?" vertex="1">
