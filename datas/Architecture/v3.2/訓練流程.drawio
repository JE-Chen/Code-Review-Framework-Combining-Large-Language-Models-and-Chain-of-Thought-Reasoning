        </mxCell>

        <mxCell id="train" parent="1" vertex="1" value="Fine-tune student (LoRA)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#e1d5e7;strokeColor=#9673a6;">
          <mxGeometry x="290" y="340" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="save" parent="1" vertex="1" value="Save adapter" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#f5f5f5;strokeColor=#666666;">
          <mxGeometry x="290" y="460" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="deploy" parent="1" vertex="1" value="Deploy to inference server" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#d4edda;strokeColor=#28a745;">
