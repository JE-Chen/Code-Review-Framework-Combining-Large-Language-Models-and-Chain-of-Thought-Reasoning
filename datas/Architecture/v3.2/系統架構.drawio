<mxfile host="app.diagrams.net">
  <diagram name="系統架構" id="v32-system-architecture">
    <mxGraphModel dx="1440" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" vertex="1" value="System Architecture (v3.2)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=22;fontStyle=1;">
          <mxGeometry x="200" y="20" width="800" height="40" as="geometry" />
        </mxCell>

        <mxCell id="trigger" parent="1" vertex="1" value="GitHub PR" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#dae8fc;strokeColor=#6c8ebf;">
          <mxGeometry x="80" y="100" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ci" parent="1" vertex="1" value="GitHub Actions&#10;(enumerate → review matrix → aggregate)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#d4edda;strokeColor=#28a745;">
          <mxGeometry x="340" y="100" width="360" height="80" as="geometry" />
        </mxCell>

        <mxCell id="edge" parent="1" vertex="1" value="Edge proxy&#10;(Cloudflare → nginx)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#ffe6cc;strokeColor=#d79b00;">
          <mxGeometry x="780" y="100" width="320" height="80" as="geometry" />
        </mxCell>

        <mxCell id="backend" parent="1" vertex="1" value="FastAPI server&#10;(sync + async job endpoints)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#d5e8d4;strokeColor=#82b366;">
          <mxGeometry x="780" y="260" width="320" height="100" as="geometry" />
        </mxCell>

        <mxCell id="pipeline" parent="1" vertex="1" value="CoT pipeline + RAG + Inference" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#f8cecc;strokeColor=#b85450;">
          <mxGeometry x="780" y="420" width="320" height="100" as="geometry" />
        </mxCell>

        <mxCell id="storage" parent="1" vertex="1" value="Storage&#10;(model + corpora + telemetry)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#f5f5f5;strokeColor=#666666;">
          <mxGeometry x="780" y="580" width="320" height="100" as="geometry" />
        </mxCell>

        <mxCell id="monitoring" parent="1" vertex="1" value="Monitoring stack&#10;(Prometheus + Grafana + cAdvisor + DCGM)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#f8d7da;strokeColor=#dc3545;">
          <mxGeometry x="340" y="420" width="360" height="100" as="geometry" />
        </mxCell>

        <mxCell id="e1" parent="1" edge="1" source="trigger" target="ci" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" parent="1" edge="1" source="ci" target="edge" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" parent="1" edge="1" source="edge" target="backend" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" parent="1" edge="1" source="backend" target="pipeline" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" parent="1" edge="1" source="pipeline" target="storage" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" parent="1" edge="1" source="monitoring" target="backend" style="endArrow=classic;html=1;dashed=1;exitX=1;exitY=0.25;entryX=0;entryY=0.75;">
          <mxGeometry relative="1" as="geometry" />
