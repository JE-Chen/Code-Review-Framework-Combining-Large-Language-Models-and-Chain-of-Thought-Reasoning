<mxfile host="app.diagrams.net">
  <diagram name="程式碼審查流程" id="v32-review-flow">
    <mxGraphModel dx="1440" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" vertex="1" value="Code Review Flow (v3.2)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=22;fontStyle=1;">
          <mxGeometry x="20" y="20" width="787" height="40" as="geometry" />
        </mxCell>

        <mxCell id="start" parent="1" vertex="1" value="PR push" style="ellipse;whiteSpace=wrap;html=1;fontSize=18;fillColor=#dae8fc;strokeColor=#6c8ebf;">
          <mxGeometry x="320" y="100" width="180" height="70" as="geometry" />
        </mxCell>

        <mxCell id="enumerate" parent="1" vertex="1" value="Enumerate files" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#d4edda;strokeColor=#28a745;">
          <mxGeometry x="290" y="220" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="matrix" parent="1" vertex="1" value="Review (matrix, per file)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#d5e8d4;strokeColor=#82b366;">
          <mxGeometry x="290" y="340" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="aggregate" parent="1" vertex="1" value="Aggregate partials" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#ffe6cc;strokeColor=#d79b00;">
          <mxGeometry x="290" y="460" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="post" parent="1" vertex="1" value="Post review to PR" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fillColor=#dae8fc;strokeColor=#6c8ebf;">
          <mxGeometry x="290" y="580" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="e1" parent="1" edge="1" source="start" target="enumerate" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" parent="1" edge="1" source="enumerate" target="matrix" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" parent="1" edge="1" source="matrix" target="aggregate" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" parent="1" edge="1" source="aggregate" target="post" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
