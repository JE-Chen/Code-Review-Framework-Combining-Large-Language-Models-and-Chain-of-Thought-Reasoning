        <mxCell id="s-incr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;fillColor=#fff2cc;strokeColor=#d6b656;" value="Incremental save (atomic)&#10;.prthinker/runs/files/&lt;file&gt;.json" vertex="1">
          <mxGeometry x="10" y="1190" width="250" height="80" as="geometry" />
