        <mxCell id="e-shard-yes" parent="1" edge="1" source="s-shard" target="s-load" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;"><mxGeometry relative="1" as="geometry" /></mxCell>
