        <mxCell id="s-emit" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;fillColor=#d4edda;strokeColor=#28a745;" value="Emit outputs&#10;PR summary (+ no-model orientation signals) · inline review · Check Run gate&#10;Reports (opt-in): SARIF · HTML · Markdown · CodeQuality · Sonar ·&#10;JUnit · CSV · metrics · GHA annotations · --report-dir" vertex="1">
          <mxGeometry x="200" y="2210" width="500" height="160" as="geometry" />
