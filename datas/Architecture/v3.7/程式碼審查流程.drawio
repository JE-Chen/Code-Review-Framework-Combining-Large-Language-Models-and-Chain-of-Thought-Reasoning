        <mxCell id="s-check" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;fillColor=#fff2cc;strokeColor=#d6b656;" value="Shard checkpoint&#10;(save partial + blob_sha to pr-state)" vertex="1">
          <mxGeometry x="270" y="1690" width="360" height="90" as="geometry" />
