        <mxCell id="lbl-yes2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=20;fontStyle=2;" value="Yes" vertex="1">
          <mxGeometry x="620" y="872" width="60" height="30" as="geometry" />
        </mxCell>
