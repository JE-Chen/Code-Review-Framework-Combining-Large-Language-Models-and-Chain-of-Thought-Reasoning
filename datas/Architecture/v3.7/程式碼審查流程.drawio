        </mxCell>

        <mxCell id="s-step" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;fillColor=#e1d5e7;strokeColor=#9673a6;" value="Run CoT step&#10;(model.generate, cancel-aware,&#10;6 000-char step output cap)" vertex="1">
