<mxfile host="app.diagrams.net">
  <diagram name="程式碼審查流程" id="v37-review-flow">
    <mxGraphModel dx="1440" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="2420" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" value="Code Review Flow (v3.7)" vertex="1">
          <mxGeometry x="200" y="10" width="540" height="44" as="geometry" />
        </mxCell>

        <mxCell id="s-push" parent="1" style="ellipse;whiteSpace=wrap;html=1;fontSize=20;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="PR push / synchronize" vertex="1">
          <mxGeometry x="330" y="70" width="240" height="64" as="geometry" />
        </mxCell>

        <mxCell id="s-restore" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;fillColor=#fff2cc;strokeColor=#d6b656;" value="Restore per-PR pr-state cache&#10;(manifest + prior partials)" vertex="1">
          <mxGeometry x="270" y="174" width="360" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-enum" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=20;" value="Enumerate PR files&#10;(filter out unchanged blob SHAs)" vertex="1">
          <mxGeometry x="270" y="294" width="360" height="80" as="geometry" />
        </mxCell>

        <mxCell id="s-shard" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=20;" value="Any file&#10;to review?" vertex="1">
          <mxGeometry x="310" y="414" width="280" height="130" as="geometry" />
        </mxCell>

        <mxCell id="lbl-no" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=20;fontStyle=2;" value="No (all cached)" vertex="1">
          <mxGeometry x="600" y="446" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lbl-yes" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=20;fontStyle=2;" value="Yes" vertex="1">
