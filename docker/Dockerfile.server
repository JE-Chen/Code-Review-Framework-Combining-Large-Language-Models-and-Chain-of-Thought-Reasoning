# prthinker inference server image.
#
# Built on the NVIDIA CUDA runtime so torch + bitsandbytes load on the GPU;
# the matching host driver must expose `--gpus all` (set via
# `runtime: nvidia` in docker-compose). The 30B-A3B model loads in bf16
# across both cards (device_map="auto") — NOT 4-bit. flash-attn is
# deliberately NOT installed: either 4-bit or flash-attn re-engages the
# transformers>=5 MoE densification path that OOMs the L40S. See CLAUDE.md
# "GPU Server: bf16, no flash-attn, no dependency pins".
#
# Heavy ML deps (torch, transformers, bitsandbytes, peft, faiss-cpu) come
# from the `[server]` extra which itself transitively includes `[local]`,
# all intentionally unpinned. Model weights are NOT baked into the image —
# they are pulled at first run into the mounted HuggingFace cache volume so
# an image rebuild does not invalidate ~80 GB of weights.

ARG CUDA_VERSION=12.2.0
FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu22.04 AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/cache/huggingface \
    TRANSFORMERS_CACHE=/cache/huggingface/hub \
    PRTHINKER_DISMISSED_PATH=/data/dismissed.jsonl \
    PRTHINKER_ACCEPTED_PATH=/data/accepted.jsonl

RUN apt-get update \
 && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        software-properties-common ca-certificates curl git gnupg \
 && add-apt-repository -y ppa:deadsnakes/ppa \
 && apt-get update \
 && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3.12 python3.12-venv python3.12-dev python3-pip \
 && update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 \
 && curl -fsS https://bootstrap.pypa.io/get-pip.py | python3.12 \
 && ln -sf /usr/local/bin/pip /usr/bin/pip \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy only metadata first so dependency layer caches across code changes.
COPY pyproject.toml ./
COPY prthinker/ ./prthinker/
COPY codes/ ./codes/
COPY datas/RAG_data/ ./datas/RAG_data/

RUN pip install --upgrade pip \
 && pip install -e ".[server]"

# Cache + JSONL stores live on a mounted volume so they survive image rebuilds.
RUN mkdir -p /cache/huggingface /data

EXPOSE 9000

# Healthcheck hits the bundled /healthz endpoint.
HEALTHCHECK --interval=30s --timeout=5s --start-period=120s --retries=3 \
  CMD curl -fsS http://127.0.0.1:9000/healthz || exit 1

CMD ["uvicorn", "codes.run.fastapi_server:app", "--host", "0.0.0.0", "--port", "9000"]
