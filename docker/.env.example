# Copy to .env and fill in. NEVER commit the real .env.

# Bearer token clients must send as `Authorization: Bearer <token>`.
# Generate one with: openssl rand -hex 32
PRTHINKER_BACKEND_TOKEN=replace-me-with-openssl-rand-hex-32

# Where to find your TLS cert + key on the host. The dir must contain
# fullchain.pem + privkey.pem (Let's Encrypt naming).
TLS_CERT_DIR=./tls

# Port on the host that nginx publishes to. 443 needs root / a privileged
# binding on Linux; use 8443 on a dev box.
PRTHINKER_HOST_PORT=443

# CUDA version of the base image. Bump to match your host driver — check
# with `nvidia-smi` and use the highest version your driver supports.
CUDA_VERSION=12.2.0
