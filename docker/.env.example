# Copy to .env and fill in. NEVER commit the real .env.

# Port on the host that the prthinker server publishes to.
# Default direct deploy: prthinker on 9000.
# TLS overlay (docker-compose.tls.yml): nginx on 443.
# Monitoring overlay (docker-compose.monitoring.yml): nginx on 9000,
# routing /grafana/, /prometheus/, /cadvisor/, /kg/ by path.
PRTHINKER_HOST_PORT=9000

# CUDA version of the base image (nvidia/cuda:<ver>-runtime-ubuntu22.04).
# 12.2.0 is the supported/tested tag; bump only to a tag that exists for
# ubuntu22.04 and that your host driver supports (check `nvidia-smi`).
CUDA_VERSION=12.2.0

# Weight precision for the GPU server. fp8 (transformers-native FineGrainedFP8)
# roughly halves the bytes read per token, speeding the memory-bandwidth-bound
# decode; bf16 is the safe fallback. The gemma4 compose defaults to fp8.
# PRTHINKER_QUANT=fp8

# Thesis ablation controls for the Gemma server. Keep one setting for an
# entire result directory and verify it through /healthz before running.
# PRTHINKER_RAG_MODE=retrieval       # retrieval | all | off
# PRTHINKER_RAG_CORPUS=relevant      # relevant | irrelevant
# PRTHINKER_DISABLE_LORA=0           # 1 serves the base model without adapter

# Host directory holding the trained Qwen3-Coder-30B LoRA adapter. Mounted
# read-only into the container at /app/codes/train/outputs-lora-qwen3-coder-30b
# (where PRTHINKER_LORA_PATH points). Override per host.
# PRTHINKER_LORA_HOST_PATH=/abs/path/to/outputs-lora-qwen3-coder-30b

# ---------------------------------------------------------------------------
# Optional — only needed when using the TLS overlay
# (docker compose -f docker-compose.server-qwen3-coder.yml -f docker-compose.tls.yml up)
# ---------------------------------------------------------------------------

# Bearer token clients must send as `Authorization: Bearer <token>`.
# Generate one with: openssl rand -hex 32
# PRTHINKER_BACKEND_TOKEN=replace-me-with-openssl-rand-hex-32

# Where to find your TLS cert + key on the host. The dir must contain
# fullchain.pem + privkey.pem (Let's Encrypt naming).
# TLS_CERT_DIR=./tls

# ---------------------------------------------------------------------------
# Optional — only needed when using the monitoring overlay
# (docker compose -f docker-compose.server-qwen3-coder.yml -f docker-compose.monitoring.yml up)
# ---------------------------------------------------------------------------

# Grafana admin login for the /grafana/ dashboard. Defaults to admin/admin
# when unset — override before exposing the overlay beyond localhost.
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=replace-me-with-openssl-rand-hex-16
